# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ── Editor ────────────────────────────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
.vscode/

# ── zsh — generated / sensitive ───────────────────────────────────────────────
.config/zsh/.zsh_history
.config/zsh/.zcompdump*
.config/zsh/.zsh_sessions/
# machine-specific overrides — not committed
.config/zsh/.zshrc.local
# antidote compiled bundle — regenerated on first shell start if missing
.config/zsh/.zsh_plugins.zsh

# ── fish — runtime / local overrides ──────────────────────────────────────────
.config/fish/tmux-client-*.log
# machine-specific overrides — not committed
.config/fish/config-local.fish
# Fisher internal state + universal vars — regenerated by `fisher install`
.config/fish/fish_variables

# ── fish — Fisher plugin files ────────────────────────────────────────────────
# All reinstalled by: fisher install  (reads fish_plugins)
# jorgebucaran/fisher
.config/fish/functions/fisher.fish
.config/fish/completions/fisher.fish
# kidonng/zoxide.fish
.config/fish/functions/__zoxide_*.fish
.config/fish/conf.d/zoxide.fish
# patrickf1/fzf.fish
.config/fish/functions/_fzf_*.fish
.config/fish/functions/fzf_configure_bindings.fish
.config/fish/completions/fzf_configure_bindings.fish
.config/fish/conf.d/fzf.fish
# jhillyerd/plugin-git
.config/fish/functions/__git.*.fish
.config/fish/functions/gbage.fish
.config/fish/functions/gbda.fish
.config/fish/functions/gdv.fish
.config/fish/functions/gignored.fish
.config/fish/functions/glp.fish
.config/fish/functions/grename.fish
.config/fish/functions/grt.fish
.config/fish/functions/gtest.fish
.config/fish/functions/gtl.fish
.config/fish/functions/gunwip.fish
.config/fish/functions/gwip.fish
.config/fish/conf.d/git.fish
# catppuccin/fish
.config/fish/themes/
# budimanjojo/tmux.fish
.config/fish/conf.d/tmux.fish
.config/fish/conf.d/tmux.extra.conf
.config/fish/conf.d/tmux.only.conf

# ── tmux — vendor code and runtime state ──────────────────────────────────────
# managed by TPM: prefix+I to install on new machine
.config/tmux/plugins/
# runtime session snapshots
.config/tmux/resurrect/

# ── yazi — installed plugins and flavors ──────────────────────────────────────
# installed by: ya pkg install  (reads package.toml)
.config/yazi/plugins/
.config/yazi/flavors/

# ── credentials / secrets ─────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
.netrc
# GitHub CLI auth token
.config/gh/hosts.yml
# 1Password CLI session
.config/op/
**/.env
**/.env.local
**/.env.*.local
*.secret
*.secrets
# may contain registry auth tokens
.npmrc
.pypirc

# ── local tool state ──────────────────────────────────────────────────────────
.config/zsh/zcompcache/
